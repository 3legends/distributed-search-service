# Application
APP_NAME="Distributed Document Search Service"
APP_VERSION="1.0.0"
DEBUG=false

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ES_INDEX_PREFIX=docs
ES_SHARDS=1
ES_REPLICAS=0

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=300

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/searchdb

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Search
MAX_SEARCH_RESULTS=100
DEFAULT_SEARCH_RESULTS=10
